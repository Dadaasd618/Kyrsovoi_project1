<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========= PALETTE (как в референсах) ========= -->
    <Color x:Key="BgDeep">#0B0820</Color>
    <Color x:Key="BgMid">#140A2D</Color>

    <Color x:Key="Text">#F3F1FF</Color>
    <Color x:Key="Text2">#B9B2D8</Color>

    <Color x:Key="Stroke">#55FFFFFF</Color>
    <Color x:Key="StrokeSoft">#22FFFFFF</Color>

    <Color x:Key="Accent">#FF7A2EFF</Color>
    <Color x:Key="Accent2">#FFC14DFF</Color>

    <Color x:Key="ControlBg">#26FFFFFF</Color>

    <Color x:Key="HeaderBg">#2A2550</Color>
    <Color x:Key="RowA">#17142A</Color>
    <Color x:Key="RowB">#1C1832</Color>

    <!-- ========= BRUSHES (ВАЖНО: Background = Brush) ========= -->
    <SolidColorBrush x:Key="BrushText" Color="{StaticResource Text}"/>
    <SolidColorBrush x:Key="BrushText2" Color="{StaticResource Text2}"/>

    <SolidColorBrush x:Key="BrushStroke" Color="{StaticResource Stroke}"/>
    <SolidColorBrush x:Key="BrushStrokeSoft" Color="{StaticResource StrokeSoft}"/>

    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="BrushAccent2" Color="{StaticResource Accent2}"/>

    <SolidColorBrush x:Key="BrushControlBg" Color="{StaticResource ControlBg}"/>

    <SolidColorBrush x:Key="BrushHeaderBg" Color="{StaticResource HeaderBg}"/>
    <SolidColorBrush x:Key="BrushRowA" Color="{StaticResource RowA}"/>
    <SolidColorBrush x:Key="BrushRowB" Color="{StaticResource RowB}"/>

    <!-- ========= EFFECTS ========= -->
    <DropShadowEffect x:Key="ShadowSoft" BlurRadius="32" ShadowDepth="10" Opacity="0.30"/>
    <DropShadowEffect x:Key="GlowPurple" Color="#AA7A2EFF" BlurRadius="44" ShadowDepth="0" Opacity="0.55"/>
    <DropShadowEffect x:Key="GlowPink" Color="#88C14DFF" BlurRadius="44" ShadowDepth="0" Opacity="0.45"/>

    <!-- ========= GLASS CARD ========= -->
    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="30"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushStrokeSoft}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="26"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#352A68" Offset="0"/>
                    <GradientStop Color="#1B1638" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect" Value="{StaticResource ShadowSoft}"/>
    </Style>

    <!-- Более “сильная” карточка (например, Login и Header) -->
    <Style x:Key="GlassCardStrong" TargetType="Border" BasedOn="{StaticResource GlassCard}">
        <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4A2B86" Offset="0"/>
                    <GradientStop Color="#211A44" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect" Value="{StaticResource GlowPurple}"/>
    </Style>

    <!-- ========= GLASS HIGHLIGHT (блик) ========= -->
    <Style x:Key="GlassHighlight" TargetType="Rectangle">
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="RadiusX" Value="30"/>
        <Setter Property="RadiusY" Value="30"/>
        <Setter Property="Opacity" Value="0.85"/>
        <Setter Property="Fill">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#40FFFFFF" Offset="0"/>
                    <GradientStop Color="#00FFFFFF" Offset="0.55"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========= BUTTONS ========= -->
    <Style x:Key="GlassButton" TargetType="Button">
        <Setter Property="Height" Value="46"/>
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="18"
                            Background="{TemplateBinding Background}">
                        <Border.Effect>
                            <DropShadowEffect Color="#AA7A2EFF" BlurRadius="30" ShadowDepth="0" Opacity="0.55"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource BrushAccent2}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassButtonSecondary" TargetType="Button" BasedOn="{StaticResource GlassButton}">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#FF6B6F7C"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="18"
                            Background="{TemplateBinding Background}">
                        <Border.Effect>
                            <DropShadowEffect Color="#55303030" BlurRadius="18" ShadowDepth="6" Opacity="0.25"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#FF7A808C"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.90"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========= INPUTS ========= -->
    <Style x:Key="GlassTextBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
        <Setter Property="Background" Value="{StaticResource BrushControlBg}"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#2AFFFFFF"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CaretBrush" Value="White"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="B"
                            CornerRadius="16"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <Rectangle RadiusX="16" RadiusY="16" Opacity="0.35">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#35FFFFFF" Offset="0"/>
                                        <GradientStop Color="#00FFFFFF" Offset="0.65"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="B" Property="BorderBrush">
                                <Setter.Value>
                                    <SolidColorBrush Color="#88C14DFF"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassPasswordBox" TargetType="PasswordBox">
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
        <Setter Property="Background" Value="{StaticResource BrushControlBg}"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#2AFFFFFF"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="B"
                            CornerRadius="16"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <Rectangle RadiusX="16" RadiusY="16" Opacity="0.35">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#35FFFFFF" Offset="0"/>
                                        <GradientStop Color="#00FFFFFF" Offset="0.65"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="B" Property="BorderBrush">
                                <Setter.Value>
                                    <SolidColorBrush Color="#88C14DFF"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassComboBox" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
        <Setter Property="Background" Value="{StaticResource BrushControlBg}"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#2AFFFFFF"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="GlassDatePicker" TargetType="DatePicker">
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
        <Setter Property="Background" Value="{StaticResource BrushControlBg}"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#2AFFFFFF"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- ========= TAB CONTROL (пилюли) ========= -->
    <Style x:Key="GlassTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="{x:Null}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="GlassTabItem" TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource BrushText2}"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="B"
                            CornerRadius="14"
                            Background="#1AFFFFFF"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="B" Property="Background" Value="#33C14DFF"/>
                            <Setter TargetName="B" Property="BorderBrush" Value="#66C14DFF"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="B" Property="Background" Value="#22FFFFFF"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========= DATAGRID ========= -->
    <Style x:Key="GlassDataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="{x:Null}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#22FFFFFF"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="RowBackground" Value="{StaticResource BrushRowA}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource BrushRowB}"/>
        <Setter Property="RowHeaderWidth" Value="0"/>

        <Setter Property="ColumnHeaderStyle">
            <Setter.Value>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource BrushHeaderBg}"/>
                    <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="12,10"/>
                    <Setter Property="BorderBrush">
                        <Setter.Value>
                            <SolidColorBrush Color="#22FFFFFF"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </Setter.Value>
        </Setter>

        <Setter Property="CellStyle">
            <Setter.Value>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="12,8"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
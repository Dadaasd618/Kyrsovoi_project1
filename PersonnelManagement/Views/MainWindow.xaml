<Window x:Class="PersonnelManagement.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Система управления персоналом"
        Width="1280" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Border CornerRadius="24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0B0820" Offset="0"/>
                    <GradientStop Color="#140A2D" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid Margin="18">
                <Ellipse Width="760" Height="760" Fill="#407A2EFF" Margin="-340,-360,0,0">
                    <Ellipse.Effect>
                        <BlurEffect Radius="220"/>
                    </Ellipse.Effect>
                </Ellipse>
                <Ellipse Width="760" Height="760" Fill="#40C14DFF" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-340,-360">
                    <Ellipse.Effect>
                        <BlurEffect Radius="220"/>
                    </Ellipse.Effect>
                </Ellipse>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="16">
                        <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Система управления персоналом"
                                           Foreground="{StaticResource BrushText}"
                                           FontSize="22" FontWeight="Bold"/>
                                <TextBlock x:Name="TbHeader"
                                           Foreground="{StaticResource BrushText2}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                
                                <Button Width="44" Height="34" Margin="0,0,10,0" Background="#22FFFFFF" BorderThickness="0" Foreground="White" Click="Help_Click" Content="?"/>
                                <Button Width="44" Height="34" Margin="0,0,10,0" Background="#22FFFFFF" BorderThickness="0" Foreground="White" Click="Minimize_Click" Content="—"/>
                                <Button Width="44" Height="34" Background="#22FFFFFF" BorderThickness="0" Foreground="White" Click="Close_Click" Content="✕"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Body -->
                    <Border Grid.Row="2" Style="{StaticResource GlassCard}">
                        <TabControl Background="Transparent" BorderThickness="0" TabStripPlacement="Top">
                            <TabControl.ItemContainerStyle>
                                <StaticResource ResourceKey="GlassTabItem"/>
                            </TabControl.ItemContainerStyle>

                            <TabControl.Template>
                                <ControlTemplate TargetType="TabControl">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" CornerRadius="18" Background="#10FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" Padding="10" Margin="0,0,0,12">
                                            <TabPanel IsItemsHost="True"/>
                                        </Border>
                                        <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                                    </Grid>
                                </ControlTemplate>
                            </TabControl.Template>

                            <!-- Сотрудники -->
                            <TabItem Header="👤Сотрудники" Margin="0,0,-6,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Добавить" Width="170" Style="{StaticResource GlassButton}" Click="AddEmployee_Click"/>
                                        <Button Content="Редактировать" Width="190" Margin="12,0,0,0" Style="{StaticResource GlassButton}" Click="EditEmployee_Click"/>
                                        <Button Content="Сделать неактивным" Width="230" Margin="12,0,0,0" Style="{StaticResource GlassButtonGray}" Click="DeactivateEmployee_Click"/>
                                        <Button Content="Обновить" Width="170" Margin="12,0,0,0" Style="{StaticResource GlassButtonGray}" Click="Refresh_Click"/>
                                    </StackPanel>
                                    <Border Grid.Row="2" CornerRadius="18" Background="#10000000" BorderBrush="#22FFFFFF" BorderThickness="1" ClipToBounds="True">
                                        <ListView x:Name="LvEmployees" 
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <ListView.Resources>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#F3F1FF"/>
                                                </Style>
                                            </ListView.Resources>
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="Фамилия" DisplayMemberBinding="{Binding LastName}" Width="120"/>
                                                    <GridViewColumn Header="Имя" DisplayMemberBinding="{Binding FirstName}" Width="120"/>
                                                    <GridViewColumn Header="Отчество" DisplayMemberBinding="{Binding MiddleName}" Width="120"/>
                                                    <GridViewColumn Header="Отдел" DisplayMemberBinding="{Binding DepartmentName}" Width="150"/>
                                                    <GridViewColumn Header="Должность" DisplayMemberBinding="{Binding RoleName}" Width="170"/>
                                                    <GridViewColumn Header="Телефон" DisplayMemberBinding="{Binding Phone}" Width="120"/>
                                                    <GridViewColumn Header="Email" DisplayMemberBinding="{Binding Email}" Width="180"/>
                                                    <GridViewColumn Header="Активен" Width="70">
                                                        <GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <CheckBox IsChecked="{Binding IsActive}" IsEnabled="False"/>
                                                            </DataTemplate>
                                                        </GridViewColumn.CellTemplate>
                                                    </GridViewColumn>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <!-- Рабочие часы -->
                            <TabItem Header="🕒Рабочие часы" RenderTransformOrigin="0.5,0.5" Margin="8,0,-26,0">
                                <TabItem.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform/>
                                        <SkewTransform AngleY="0.314"/>
                                        <RotateTransform/>
                                        <TranslateTransform Y="0.195"/>
                                    </TransformGroup>
                                </TabItem.RenderTransform>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Добавить запись" Width="200" Style="{StaticResource GlassButton}" Click="AddTimeEntry_Click"/>
                                        <Button Content="Последние 30 дней" Width="200" Margin="12,0,0,0" Style="{StaticResource GlassButtonGray}" Click="LoadLast30_Click"/>
                                    </StackPanel>
                                    <Border Grid.Row="2" CornerRadius="16" Background="#14FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="240"/>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="240"/>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="C:" Foreground="{StaticResource BrushText2}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <DatePicker x:Name="DpStart" Grid.Column="1"/>
                                            <TextBlock Grid.Column="3" Text="По:" Foreground="{StaticResource BrushText2}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <DatePicker x:Name="DpEnd" Grid.Column="4"/>
                                            <Button Grid.Column="6" Content="Загрузить" Width="100" Style="{StaticResource GlassButtonGray}" Click="LoadTimeByPeriod_Click"/>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Row="4" CornerRadius="18" Background="#10000000" BorderBrush="#22FFFFFF" BorderThickness="1" ClipToBounds="True">
                                        <ListView x:Name="LvTime" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                            <ListView.Resources>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#F3F1FF"/>
                                                </Style>
                                            </ListView.Resources>
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="Дата" DisplayMemberBinding="{Binding WorkDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                                                    <GridViewColumn Header="Сотрудник" DisplayMemberBinding="{Binding EmployeeName}" Width="200"/>
                                                    <GridViewColumn Header="Тип смены" DisplayMemberBinding="{Binding ShiftName}" Width="120"/>
                                                    <GridViewColumn Header="Начало" DisplayMemberBinding="{Binding StartTime}" Width="70"/>
                                                    <GridViewColumn Header="Конец" DisplayMemberBinding="{Binding EndTime}" Width="70"/>
                                                    <GridViewColumn Header="Перерыв (мин)" DisplayMemberBinding="{Binding BreakMinutes}" Width="120"/>
                                                    <GridViewColumn Header="Часов" DisplayMemberBinding="{Binding HoursWorked}" Width="80"/>
                                                    <GridViewColumn Header="Комментарий" DisplayMemberBinding="{Binding Comment}" Width="200"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <!-- Отчёты -->
                            <TabItem Header="📄Отчёты" Margin="30,0,-48,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <ComboBox x:Name="CbReportType" Width="200" Margin="0,0,12,0" SelectedIndex="0">
                                            <ComboBoxItem Content="Отработанные часы"/>
                                            <ComboBoxItem Content="Отсутствия (отпуск/больничный)"/>
                                            <ComboBoxItem Content="Сводка по сотруднику"/>
                                        </ComboBox>
                                        <DatePicker x:Name="RpStart" Width="140" Margin="0,0,12,0"/>
                                        <TextBlock Text="—" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <DatePicker x:Name="RpEnd" Width="140" Margin="0,0,12,0"/>
                                        <Button Content="Сформировать" Width="150" Style="{StaticResource GlassButton}" Click="BuildReport_Click"/>
                                        <Button Content="Экспорт" Width="100" Margin="12,0,0,0" Style="{StaticResource GlassButtonGray}" Click="ExportReport_Click"/>
                                    </StackPanel>
                                    <Border Grid.Row="4" CornerRadius="18" Background="#10000000" BorderBrush="#22FFFFFF" BorderThickness="1" ClipToBounds="True">
                                        <ListView x:Name="LvReport" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                            <ListView.Resources>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#F3F1FF"/>
                                                </Style>
                                            </ListView.Resources>
                                            <ListView.View>
                                                <GridView x:Name="ReportGridView"/>
                                            </ListView.View>
                                        </ListView>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <!-- Управление отсутствиями -->
                            <TabItem Header="🕹️Управление отсутствиями" Margin="51,0,-60,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <ComboBox x:Name="CbEmployeeForStatus" Width="195" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,12,0"/>
                                        <ComboBox x:Name="CbStatusType" Width="150" Margin="0,0,12,0" SelectedIndex="0">
                                            <ComboBoxItem Content="Отпуск"/>
                                            <ComboBoxItem Content="Больничный"/>
                                            <ComboBoxItem Content="Командировка"/>
                                        </ComboBox>
                                        <DatePicker x:Name="DpStatusStart" Width="120" Margin="0,0,12,0"/>
                                        <TextBlock Text="—" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <DatePicker x:Name="DpStatusEnd" Width="120" Margin="0,0,12,0"/>
                                        <Button Content="Добавить" Width="120" Style="{StaticResource GlassButton}" Click="AddStatus_Click"/>
                                        <Button Content="Обновить" Width="120" Margin="12,0,0,0" Style="{StaticResource GlassButtonGray}" Click="RefreshStatuses_Click"/>
                                    </StackPanel>
                                    <Border Grid.Row="4" CornerRadius="18" Background="#10000000" BorderBrush="#22FFFFFF" BorderThickness="1" ClipToBounds="True">
                                        <ListView x:Name="LvStatuses" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                            <ListView.Resources>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#F3F1FF"/>
                                                </Style>
                                            </ListView.Resources>
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="Сотрудник" DisplayMemberBinding="{Binding EmployeeName}" Width="200"/>
                                                    <GridViewColumn Header="Тип" DisplayMemberBinding="{Binding StatusType}" Width="120"/>
                                                    <GridViewColumn Header="Дата начала" DisplayMemberBinding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                                                    <GridViewColumn Header="Дата окончания" DisplayMemberBinding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                                                    <GridViewColumn Header="Дней" DisplayMemberBinding="{Binding DaysCount}" Width="70"/>
                                                    <GridViewColumn Header="Комментарий" DisplayMemberBinding="{Binding Comment}" Width="200"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </Border>
                                </Grid>
                            </TabItem>

                        </TabControl>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
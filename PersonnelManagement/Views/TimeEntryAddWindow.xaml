<Window x:Class="PersonnelManagement.Views.TimeEntryAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить табель"
        Width="760" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Grid>
        <Border CornerRadius="26">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#140A2D" Offset="0"/>
                    <GradientStop Color="#0B0820" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Ellipse Width="760" Height="760" Fill="#407A2EFF" Margin="-380,-380,0,0">
                    <Ellipse.Effect>
                        <BlurEffect Radius="220"/>
                    </Ellipse.Effect>
                </Ellipse>
                <Ellipse Width="760" Height="760" Fill="#40C14DFF"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,-380,-380">
                    <Ellipse.Effect>
                        <BlurEffect Radius="220"/>
                    </Ellipse.Effect>
                </Ellipse>

                <Border Margin="22"
                        CornerRadius="22"
                        Background="#16FFFFFF"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        Padding="18">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="26" ShadowDepth="10" Opacity="0.22"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Добавление рабочего времени"
                                       Foreground="#F3F1FF"
                                       FontSize="26"
                                       FontWeight="Bold"/>

                            <Button Grid.Column="1"
                                    Width="40" Height="30"
                                    Background="#22FFFFFF"
                                    BorderThickness="0"
                                    Foreground="White"
                                    Content="✕"
                                    Click="Close_Click"/>
                        </Grid>

                        <!-- Form -->
                        <StackPanel Grid.Row="2" Margin="0,8,0,0">

                            <TextBlock Text="Сотрудник" Foreground="#CFC7EE" Margin="0,0,0,6"/>
                            <ComboBox x:Name="CbEmployee"
                                      Height="40"
                                      DisplayMemberPath="FullName"
                                      SelectedValuePath="EmployeeId"/>

                            <TextBlock Text="Тип смены" Foreground="#CFC7EE" Margin="0,12,0,6"/>
                            <ComboBox x:Name="CbShift"
                                      Height="40"
                                      DisplayMemberPath="ShiftName"
                                      SelectedValuePath="ShiftTypeId"/>

                            <TextBlock Text="Дата" Foreground="#CFC7EE" Margin="0,12,0,6"/>
                            <DatePicker x:Name="DpDate" Height="40"/>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Начало(чаc/мин)" Foreground="#CFC7EE" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TbStart" Height="40" Text="09:00"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Конец(час/мин)" Foreground="#CFC7EE" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TbEnd" Height="40" Text="18:00"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Перерыв (минуты)" Foreground="#CFC7EE" Margin="0,12,0,6"/>
                            <TextBox x:Name="TbBreak" Height="40" Text="60"/>

                            <TextBlock Text="Комментарий" Foreground="#CFC7EE" Margin="0,12,0,6"/>
                            <TextBox x:Name="TbComment" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

                        </StackPanel>

                        <!-- Buttons -->
                        <Grid Grid.Row="3" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="Сохранить"
                                    Style="{StaticResource GlassButton}"
                                    Click="Save_Click"/>

                            <Button Grid.Column="2"
                                    Content="Отмена"
                                    Height="42"
                                    Background="#33FFFFFF"
                                    BorderThickness="0"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    Click="Cancel_Click"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>